{% extends 'base.html.twig' %}

{% block title %}Produit{% endblock %}

{% block body %}
    <section class="product-card product-detail">
        <div class="product-image product-detail-image">
            {% if product.imagePath %}
                <img src="{{ asset(product.imagePath) }}" alt="{{ product.name }}" onerror="this.remove(); this.parentElement.textContent='Image produit';">
            {% else %}
                Image produit
            {% endif %}
        </div>

        <div>
            <h2 class="product-name">{{ product.name }}</h2>
            <p class="product-price"><strong>Prix :</strong> {{ product.price|number_format(2, ',', ' ') }} €</p>

            {{ form_start(addToCartForm) }}
                <div class="form-row">{{ form_row(addToCartForm.size) }}</div>
                <button class="btn" type="submit">AJOUTER AU PANIER</button>
            {{ form_end(addToCartForm) }}
        </div>
    </section>
{% endblock %}
